---
import type { Product } from "@/types";
// import RenderIf from './RenderIf.astro';
import ColorOptions from "./ColorOptions.astro";

// const product = {
//   id: "prod-001",
//   title: "Sony WH-1000XM5 Noise Canceling",
//   description: "Sumérgete en el sonido con la cancelación de ruido líder en la industria y un diseño ultraligero.",
//   price: 349.00,
//   originalPrice: 419.99,
//   currency: "$",
//   image: "https://images.unsplash.com/photo-1618366712010-f4ae9c647dcb?q=80&w=1000&auto=format&fit=crop",
//   badge: "Oferta",
//   colors: [
//     { name: "Midnight Black", hex: "#1a1a1a", twClass: "bg-neutral-900" },
//     { name: "Silver", hex: "#e0e0e0", twClass: "bg-gray-200" },
//     { name: "Navy Blue", hex: "#1e3a8a", twClass: "bg-blue-900" }
//   ],
//   rating: 4.8
// };

interface Props {
  product: Product;
}

const { product } = Astro.props;
const discount = Math.round(
  ((product.price - product.price) / product.price) * 100
);
---

<article
  data-product-id={product.id}
  class="group relative flex flex-col w-full max-w-[380px] bg-white rounded-2xl cursor-pointer border border-gray-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 ease-out overflow-hidden mx-auto sm:mx-0"
>
  <div class="relative w-full aspect-[4/3] overflow-hidden bg-gray-100">
    <!-- <RenderIf condition={!!product.badge}>
      <span class="absolute top-3 left-3 z-10 bg-red-500 text-white text-xs font-bold px-3 py-1 rounded-full shadow-sm">
        {product.badge} -{discount}%
      </span>
    </RenderIf> -->

    <img
      src={`/api/image/${product.images[0].directus_files_id}`}
      alt={`Imagen de ${product.name}`}
      class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
      loading="lazy"
    />
  </div>

  <div class="flex flex-col flex-grow p-6 gap-3">
    <div class="flex justify-between items-start gap-4">
      <h2 class="text-lg font-bold leading-snug text-gray-900">
        <a
          href={`/product/${product.id}`}
          class="hover:text-indigo-600 transition-colors"
        >
          {product.name}
        </a>
      </h2>
    </div>

    <p class="text-sm text-gray-500 line-clamp-2 leading-relaxed">
      {product.description}
    </p>

    <ColorOptions colors={product.colors} />

    <!-- Footer: Precio y Botón -->
    <div
      class="flex items-center justify-end mt-3 pt-4 border-t border-gray-100"
    >
      <div class="flex flex-col">
        <span class="text-xl font-extrabold text-gray-900">
          $ {product.price} ARS
        </span>
      </div>

      <!-- <button class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg shadow-sm hover:shadow transition-all duration-200 active:scale-95">
        Añadir +
      </button> -->
    </div>
  </div>
</article>