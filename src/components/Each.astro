---
interface Props {
  of: any[];
  renderAs: (item: any, index: number) => any;
}

const { of = [], renderAs } = Astro.props;

if (!Array.isArray(of)) {
  throw new Error('Each component: "of" prop must be an array');
}
if (typeof renderAs !== 'function') {
  throw new Error('Each component: "renderAs" prop must be a function');
}
---

{
  of.map((item, index) => renderAs(item, index))
}
