---
import Layout from "@/layouts/Layout.astro";
import { getProduct } from "@/server/utils";
import ColorOptions from "@/components/ColorOptions.astro";
import If from "@/components/If.astro";

const { id } = Astro.params;
const product = id ? await getProduct(id) : null;

const formatter = new Intl.NumberFormat('es-AR', {
  style: 'currency',
  currency: 'ARS'
});

const formattedPrice = product ? formatter.format(product.price) : '';
const mainImage = product?.images?.[0];
const secondaryImages = product?.images?.slice(1) ?? [];
---

<Layout>
  <main class="min-h-screen bg-gradient-to-br from-slate-50 via-white to-indigo-50/60">
    <div class="mx-auto max-w-6xl px-4 py-8 lg:py-12">
      <div class="mb-6 text-sm text-gray-500">
        <nav class="flex flex-wrap items-center gap-1">
          <a href="/" class="hover:text-gray-800">Inicio</a>
          <span>/</span>
          <a href="/catalogo" class="hover:text-gray-800">Catálogo</a>
          <span>/</span>
          <span class="font-medium text-gray-800">{product?.name ?? "Producto"}</span>
        </nav>
      </div>

      {product ? (
        <section class="grid gap-8 lg:grid-cols-[1.1fr,0.9fr]">
          <div class="space-y-4">
            <div class="relative overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-lg">
              <div class="absolute left-6 top-6 z-10 flex flex-col gap-2">
                <span class="inline-flex items-center gap-2 rounded-full bg-indigo-600/90 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white shadow-md">
                  Nuevo lanzamiento
                </span>
                <span class="inline-flex items-center gap-2 rounded-full bg-white/90 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-indigo-600 shadow-md ring-1 ring-indigo-100">
                  SKU {product.sku}
                </span>
              </div>
              {mainImage ? (
                <img
                  data-main-image
                  src={`/api/image/${mainImage.directus_files_id}`}
                  alt={`Imagen principal de ${product.name}`}
                  class="h-full w-full max-h-[540px] object-cover transition-transform duration-700 ease-out hover:scale-[1.02]"
                />
              ) : (
                <div class="flex h-full min-h-[420px] items-center justify-center bg-slate-100 text-sm text-slate-500">
                  Sin imagen disponible
                </div>
              )}
            </div>

            {product.images.length > 1 && (
              <div class="grid grid-cols-2 gap-4 sm:grid-cols-3">
                {[mainImage, ...secondaryImages].filter(Boolean).map((image, index) => (
                  <button
                    type="button"
                    data-thumb
                    data-src={`/api/image/${image!.directus_files_id}`}
                    aria-label={`Vista ${index + 1} de ${product.name}`}
                    class="group relative overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-md"
                  >
                    <span class="absolute inset-0 bg-gradient-to-br from-indigo-500/0 via-indigo-500/0 to-indigo-500/10 opacity-0 transition group-hover:opacity-100" />
                    <img
                      src={`/api/image/${image!.directus_files_id}`}
                      alt={`Miniatura ${index + 1} de ${product.name}`}
                      class="h-32 w-full object-cover transition duration-300 group-hover:scale-105"
                    />
                  </button>
                ))}
              </div>
            )}
          </div>

          <div class="flex flex-col gap-6 rounded-3xl border border-slate-200 bg-white/90 p-6 shadow-xl backdrop-blur">
            <div class="space-y-2 border-b border-slate-200 pb-4">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-indigo-600">Colección Premium</p>
              <h1 class="text-3xl font-bold leading-tight text-slate-900">{product.name}</h1>
              <p class="text-sm text-slate-500">Descubre la calidad de nuestra marroquinería importada con acabados de lujo.</p>
            </div>

            <div class="flex flex-col gap-3 rounded-2xl bg-slate-50 px-4 py-3 ring-1 ring-slate-200">
              <div class="flex items-baseline gap-3">
                <span class="text-3xl font-extrabold text-slate-900">{formattedPrice}</span>
                <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-emerald-700">En stock</span>
              </div>
              <p class="text-sm text-slate-500">Precio final con impuestos incluidos. Pagá en hasta 3 cuotas sin interés.</p>
            </div>

            <div class="space-y-3">
              <div class="flex items-center gap-3 text-sm text-slate-600">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-indigo-50 text-indigo-600">★</span>
                <div>
                  <p class="font-semibold text-slate-800">Experiencia premium garantizada</p>
                  <p class="text-xs text-slate-500">Materiales seleccionados, costuras reforzadas y controles de calidad estrictos.</p>
                </div>
              </div>
              <div class="flex items-center gap-3 text-sm text-slate-600">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-indigo-50 text-indigo-600">🚚</span>
                <div>
                  <p class="font-semibold text-slate-800">Envíos rápidos en todo el país</p>
                  <p class="text-xs text-slate-500">Despachamos en 24 hs hábiles con seguimiento en línea.</p>
                </div>
              </div>
            </div>

            <div class="space-y-3">
              <p class="text-sm font-semibold uppercase tracking-[0.12em] text-slate-500">Colores</p>
              {product.colors.length > 0 ? (
                <div class="flex flex-wrap gap-3">
                  {product.colors.map((color) => (
                    <button
                      type="button"
                      class="group flex items-center gap-2 rounded-full border border-slate-200 bg-white px-3 py-2 shadow-sm transition hover:-translate-y-0.5 hover:border-indigo-200 hover:shadow-md"
                    >
                      <span
                        class="h-8 w-8 rounded-full border border-slate-200 ring-2 ring-transparent transition group-hover:ring-indigo-200"
                        style={`background-color: ${color.code};`}
                        aria-label={`Color ${color.name}`}
                      />
                      <span class="text-sm font-medium text-slate-700">{color.name}</span>
                    </button>
                  ))}
                </div>
              ) : (
                <p class="text-sm text-slate-500">Próximamente más variantes de color.</p>
              )}
            </div>

            <div class="grid gap-3 sm:grid-cols-2">
              <button class="inline-flex items-center justify-center gap-2 rounded-2xl bg-indigo-600 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-200 transition hover:-translate-y-0.5 hover:bg-indigo-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">
                Añadir al carrito
              </button>
              <button class="inline-flex items-center justify-center gap-2 rounded-2xl border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-800 shadow-sm transition hover:-translate-y-0.5 hover:border-indigo-200 hover:text-indigo-700 hover:shadow-md">
                Consultar por mayorista
              </button>
            </div>

            <div class="space-y-3 rounded-2xl border border-slate-200 bg-slate-50 px-5 py-4">
              <p class="text-sm font-semibold text-slate-800">Descripción</p>
              <p class="text-sm leading-relaxed text-slate-600">{product.description}</p>
            </div>

            <div class="grid gap-4 rounded-2xl border border-slate-200 bg-white px-5 py-4 sm:grid-cols-3">
              <div class="rounded-xl bg-indigo-50 px-3 py-2 text-indigo-700">
                <p class="text-xs font-semibold uppercase tracking-wide">Garantía</p>
                <p class="text-sm font-semibold">12 meses</p>
                <p class="text-xs text-indigo-600/80">Cambio directo por fallas de fábrica</p>
              </div>
              <div class="rounded-xl bg-emerald-50 px-3 py-2 text-emerald-700">
                <p class="text-xs font-semibold uppercase tracking-wide">Cuidados</p>
                <p class="text-sm font-semibold">Resistente al uso diario</p>
                <p class="text-xs text-emerald-600/80">Recomendamos limpiarla con paño húmedo</p>
              </div>
              <div class="rounded-xl bg-amber-50 px-3 py-2 text-amber-700">
                <p class="text-xs font-semibold uppercase tracking-wide">Entrega</p>
                <p class="text-sm font-semibold">48 a 72 hs hábiles</p>
                <p class="text-xs text-amber-600/80">Retirá gratis en nuestras sucursales</p>
              </div>
            </div>
          </div>
        </section>
      ) : (
        <div class="rounded-3xl border border-slate-200 bg-white p-10 text-center shadow-sm">
          <p class="text-lg font-semibold text-slate-800">Producto no encontrado</p>
          <p class="mt-2 text-sm text-slate-500">El artículo que buscás no está disponible o fue retirado del catálogo.</p>
          <a
            href="/catalogo"
            class="mt-5 inline-flex items-center justify-center gap-2 rounded-2xl bg-indigo-600 px-5 py-3 text-sm font-semibold text-white shadow-lg transition hover:-translate-y-0.5 hover:bg-indigo-700"
          >
            Volver al catálogo
          </a>
        </div>
      )}
    </div>
  </main>
</Layout>

{product && (
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const mainImage = document.querySelector('[data-main-image]');
      const thumbnails = Array.from(document.querySelectorAll('[data-thumb]'));

      thumbnails.forEach((thumb) => {
        thumb.addEventListener('click', () => {
          const src = thumb.getAttribute('data-src');

          thumbnails.forEach((item) => item.classList.remove('ring-2', 'ring-indigo-400'));
          thumb.classList.add('ring-2', 'ring-indigo-400');

          if (src && mainImage instanceof HTMLImageElement) {
            mainImage.src = src;
          }
        });
      });
    });
  </script>
)}
