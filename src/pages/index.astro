---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import AboutSection from '../components/AboutSection.astro';
import PurchaseConditions from '../components/PurchaseConditions.astro';
import HistorySection from '../components/HistorySection.astro';
import { getSettings } from '@/server/utils';

const settings = await getSettings();

const carrouselImgs = settings.carrouselProducts.flatMap(product => product.images)
---

<Layout settings={settings}>
  <main>
    <Hero businessTitle={settings.businessTitle} businessPresentation={settings.businessPresentation} carrouselImages={carrouselImgs} />
    <AboutSection aboutUs={settings.aboutUs} />
    <PurchaseConditions />
    <HistorySection />
  </main>
</Layout>
