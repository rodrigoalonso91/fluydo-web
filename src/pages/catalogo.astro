---
import Layout from "@/layouts/Layout.astro";
import { getProducts } from "@/server/utils";
import { getSecret } from "astro:env/server";
import NoAvaliableProducts from "@/components/NoAvaliableProducts.astro";
import If from "@/components/If.astro";
import ProductCard from "@/components/ProductCard.astro";

const products = await getProducts();
---

<Layout>
  <main class="mx-auto max-w-6xl px-4 py-6 lg:py-10">

    <div class="mb-4 text-sm text-gray-500">
      <nav class="flex flex-wrap items-center gap-1">
        <a href="/" class="hover:text-gray-800">Inicio</a>
        <span>/</span>
        <span class="font-medium text-gray-800">Catálogo</span>
      </nav>
    </div>

    <header class="mb-6 flex flex-col justify-between gap-4 border-b border-gray-200 pb-4 md:flex-row md:items-end">
      <div>
        <h1 class="text-2xl font-semibold tracking-tight text-gray-900 md:text-3xl">
          Productos
        </h1>
        <p class="mt-1 text-sm text-gray-500">
          {products.length} productos encontrados
        </p>
      </div>

      <div class="flex flex-wrap items-center gap-3 text-sm text-gray-600">
        <span class="font-medium">Ordenar por:</span>
        <select id="order-by" class="rounded border border-gray-300 bg-white px-2.5 py-1 text-sm shadow-sm focus:border-gray-400 focus:outline-none">
          <option value="price-asc">Precio: menor a mayor</option>
          <option value="price-desc">Precio: mayor a menor</option>
          <option value="name-asc">Alfabético: A-Z</option>
          <option value="name-desc">Alfabético: Z-A</option>
          <option value="sku-asc">SKU: menor a mayor</option>
          <option value="sku-desc">SKU: mayor a menor</option>
        </select>
      </div>
    </header>

    <If condition={products.length === 0}>
      <NoAvaliableProducts slot="then" />

      <div slot="else" class="grid gap-8 lg:grid-cols-[260px,1fr]">
        <aside class="space-y-6 border-gray-200 lg:border-r lg:pr-6">
          
          <!-- <section class="space-y-3">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">
              Categorías
            </h2>
            <div class="space-y-1 text-sm text-gray-600">
              <button class="block w-full text-left hover:text-gray-900">Ver todo</button>
              <button class="block w-full text-left hover:text-gray-900">Carteras</button>
              <button class="block w-full text-left hover:text-gray-900">Mochilas</button>
              <button class="block w-full text-left hover:text-gray-900">Billeteras</button>
            </div>
          </section> -->

          <!-- <section class="space-y-3">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">
              Rango de precio
            </h2>
            <div class="flex items-center gap-2 text-sm text-gray-600">
              <input
                type="number"
                placeholder="$ Mín"
                class="w-full rounded border border-gray-300 px-2 py-1 text-sm focus:border-gray-400 focus:outline-none"
              />
              <span class="text-xs text-gray-500">a</span>
              <input
                type="number"
                placeholder="$ Máx"
                class="w-full rounded border border-gray-300 px-2 py-1 text-sm focus:border-gray-400 focus:outline-none"
              />
            </div>
          </section> -->

          <!-- <section class="space-y-3">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-700">
              Colores
            </h2>
            <div class="flex flex-wrap gap-2">
              <button class="h-7 w-7 rounded-full border border-gray-300 bg-black" aria-label="Negro" />
              <button class="h-7 w-7 rounded-full border border-gray-300 bg-brown-700" aria-label="Marrón" />
              <button class="h-7 w-7 rounded-full border border-gray-300 bg-red-700" aria-label="Rojo" />
              <button class="h-7 w-7 rounded-full border border-gray-300 bg-gray-300" aria-label="Gris" />
            </div>
          </section> -->
        </aside>

        <section class="space-y-4">
          <div id="product-grid" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {products.filter(product => !!product).map((product) => (
              <a
                class="contents"
                href={`/product/${product.id}`}
                data-product-name={product.name}
                data-product-price={product.price}
                data-product-sku={product.sku}
              >
                <ProductCard product={product} />
              </a>
            ))}
          </div>
        </section>
      </div>
    </If>
  </main>

  <script>

    const orderBySelect = document.getElementById("order-by") as HTMLSelectElement;
    const productGrid = document.querySelector("#product-grid");

    if (orderBySelect && productGrid) {
      const items: HTMLAnchorElement[] = Array.from(productGrid.querySelectorAll("a.contents"));

      const compareStrings = (a: string, b: string, direction = "asc") => {
        const result = a.localeCompare(b, "es", { sensitivity: "base" });
        return direction === "asc" ? result : -result;
      };

      const getSortValue = (item: HTMLAnchorElement, key: string) => item.dataset[key] ?? "";

      const sortItems = (value: string) => {
        const sorted = [...items].sort((itemA, itemB) => {
          switch (value) {
            case "price-desc":
              return (
                Number(getSortValue(itemB, "productPrice")) -
                Number(getSortValue(itemA, "productPrice"))
              );
            case "name-asc":
              return compareStrings(
                getSortValue(itemA, "productName"),
                getSortValue(itemB, "productName"),
                "asc"
              );
            case "name-desc":
              return compareStrings(
                getSortValue(itemA, "productName"),
                getSortValue(itemB, "productName"),
                "desc"
              );
            case "sku-asc":
              return compareStrings(
                getSortValue(itemA, "productSku"),
                getSortValue(itemB, "productSku"),
                "asc"
              );
            case "sku-desc":
              return compareStrings(
                getSortValue(itemA, "productSku"),
                getSortValue(itemB, "productSku"),
                "desc"
              );
            case "price-asc":
            default:
              return (
                Number(getSortValue(itemA, "productPrice")) -
                Number(getSortValue(itemB, "productPrice"))
              );
          }
        });

        productGrid.replaceChildren(...sorted);
      };

      sortItems(orderBySelect.value || "price-asc");

      orderBySelect.addEventListener("change", (event) => {
        const target = event.target;
        if (target instanceof HTMLSelectElement) {
          sortItems(target.value);
        }
      });
    }
  </script>
</Layout>
